# ── Local ──────────────────────────────────────────────
DATABASE_URL="postgresql://kiyap:kiyap1234@localhost:5432/kiyap"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="kiyap-super-secret-jwt-key-change-in-production-2024"
NEXTAUTH_URL="http://localhost:3000"
NODE_ENV="development"

# ── fly.io (fly secrets set KEY=VALUE) ─────────────────
# DATABASE_URL="<fly postgres 연결 문자열>"
#   → fly postgres create --name kiyap-db
#   → fly postgres attach kiyap-db  (자동 주입)
#
# REDIS_URL="<upstash or fly redis 연결 문자열>"
#   → fly redis create --name kiyap-redis
#   → fly redis attach kiyap-redis  (자동 주입)
#
# JWT_SECRET="<강력한 랜덤 문자열>"
#   → openssl rand -base64 32
#   → fly secrets set JWT_SECRET="..."
#
# NEXTAUTH_URL="https://kiyap.fly.dev"
#   → fly secrets set NEXTAUTH_URL="https://kiyap.fly.dev"
